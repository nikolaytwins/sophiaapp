# ─── ОБРАЗЕЦ переменных (без секретов). ───
#
# Проще всего: в корне проекта есть файл sophia.env.template — скопируй его в sophia.env
# и заполни (sophia.env виден в списке файлов и подхватывается Expo).
# Альтернатива: скрытый файл .env (Cmd+O → вставить путь …/sophia-os/.env).

# After Dark: astro API (PyEphem). На Mac в браузере :8081 обычно достаточно дефолта из app.config.js (127.0.0.1:8765).
# EXPO_PUBLIC_ASTRO_API_URL=http://127.0.0.1:8765
# Телефон в LAN — IP твоего Mac:
# EXPO_PUBLIC_ASTRO_API_URL=http://192.168.1.10:8765

# Привычки: свой сервер синка (альтернатива Supabase). Не нужно, если используешь Supabase.
# EXPO_PUBLIC_SOPHIA_HABITS_URL=https://your-domain.example/habits-api
# EXPO_PUBLIC_SOPHIA_HABITS_SYNC_KEY=replace-with-long-random-secret

# Supabase — облако привычек. Dashboard → Settings → API Keys (URL + legacy anon public eyJ…)
EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Teamtracker (Next, обычно порт 3003): выручка агентства на финансовом дашборде Sophia.
# В team-tracker/.env.local — TT_INTEGRATION_SECRET (тот же текст, ≥16 символов).
# Прод (поддомен без /pm-board): EXPO_PUBLIC_TEAMTRACKER_URL=https://tt.twinlabs.ru
# Локально с /pm-board: http://127.0.0.1:3003/pm-board
# EXPO_PUBLIC_TEAMTRACKER_URL=https://tt.twinlabs.ru
# EXPO_PUBLIC_TEAMTRACKER_INTEGRATION_SECRET=same-as-TT_INTEGRATION_SECRET
